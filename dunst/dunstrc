[global]
monitor = 0
follow = none
width = 320
height = (0, 300)
origin = top-right
offset = (16, 48)
scale = 0
notification_limit = 10

progress_bar = true
progress_bar_height = 8
progress_bar_frame_width = 0
progress_bar_min_width = 150
progress_bar_max_width = 320
progress_bar_corner_radius = 6
progress_bar_corners = all

icon_corner_radius = 6
icon_corners = all

indicate_hidden = yes
transparency = 10

separator_height = 0
padding = 10
horizontal_padding = 12
text_icon_padding = 8

frame_width = 1
frame_color = "#000000"
gap_size = 8
separator_color = frame
sort = update

font = Inter 10
line_height = 0
markup = full
format = "<b>%s</b>\n%b"
alignment = left
vertical_alignment = center
show_age_threshold = 60
ellipsize = end
ignore_newline = no
stack_duplicates = true
hide_duplicate_count = false
show_indicators = yes

enable_recursive_icon_lookup = true
icon_theme = Adwaita
icon_position = left
min_icon_size = 24
max_icon_size = 64
icon_path = /usr/share/icons

sticky_history = yes
history_length = 20

dmenu = /usr/bin/dmenu -p dunst:
browser = /usr/bin/xdg-open
always_run_script = true
title = Dunst
class = Dunst

corner_radius = 12
corners = all
ignore_dbusclose = false
force_xwayland = false
force_xinerama = false

mouse_left_click = close_current
mouse_middle_click = do_action, close_current
mouse_right_click = close_all

[urgency_low]
background = "#1a1a1a"
foreground = "#8a8a8a"
timeout = 6

[urgency_normal]
background = "#111111"
foreground = "#eaeaea"
timeout = 8

[urgency_critical]
background = "#3a0f0f"
foreground = "#ffffff"
frame_color = "#ff5555"
timeout = 0

[experimental]
per_monitor_dpi = false
